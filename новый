        self.price_entry.grid(row=2, column=1, sticky='w', padx=5, pady=5)
        
        # Дата покупки
        ttk.Label(add_frame, text="Дата:").grid(row=3, column=0, sticky='w', pady=5)
        self.date_var = tk.StringVar(value=datetime.now().strftime("%Y-%m-%d"))
        self.date_entry = ttk.Entry(add_frame, textvariable=self.date_var, width=15)
        self.date_entry.grid(row=3, column=1, sticky='w', padx=5, pady=5)
        
        # Магазин
        ttk.Label(add_frame, text="Магазин:").grid(row=4, column=0, sticky='w', pady=5)
        self.store_var = tk.StringVar()
        self.store_entry = ttk.Entry(add_frame, textvariable=self.store_var, width=30)
        self.store_entry.grid(row=4, column=1, sticky='w', padx=5, pady=5)
        
        # Кнопка добавления
        ttk.Button(add_frame, text="Добавить покупку", command=self.add_expense).grid(
