    def create_chart(self):
        """Создание графика расходов"""
        chart_frame = ttk.LabelFrame(self.stats_frame, text="График расходов по дням", padding=10)
        chart_frame.pack(fill='both', expand=True, padx=10, pady=10)
        
        # Создаем фигуру matplotlib
        self.figure, self.ax = plt.subplots(figsize=(8, 3))
        self.canvas = FigureCanvasTkAgg(self.figure, chart_frame)
        self.canvas.get_tk_widget().pack(fill='both', expand=True)
    
    def create_category_stats(self):
        """Создание статистики по категориям"""
        cat_frame = ttk.LabelFrame(self.stats_frame, text="Расходы по категориям", padding=10)
        cat_frame.pack(fill='x', padx=10, pady=10)
        
        self.category_tree = ttk.Treeview(cat_frame, 
                                         columns=('category', 'total', 'percentage'), 
                                         show='headings', height=5)
        
        self.category_tree.heading('category', text='Категория')
        self.category_tree.heading('total', text='Сумма')
        self.category_tree.heading('percentage', text='% от общих затрат')
        
        self.category_tree.column('category', width=200)
        self.category_tree.column('total', width=150)
        self.category_tree.column('percentage', width=150)
        
        self.category_tree.pack()
    
    def add_expense(self):
        """Добавление новой покупки"""
        product = self.product_var.get()
        try:
            quantity = float(self.quantity_var.get())
            price = float(self.price_var.get())
        except ValueError:
            messagebox.showerror("Ошибка", "Пожалуйста, введите корректные числа")
            return
        
        date = self.date_var.get()
        store = self.store_var.get()
        
        if not product:
            messagebox.showerror("Ошибка", "Пожалуйста, выберите продукт")
            return
        
        # Проверяем дату
        try:
            datetime.strptime(date, "%Y-%m-%d")
        except ValueError:
            messagebox.showerror("Ошибка", "Неверный формат даты. Используйте YYYY-MM-DD")
            return
        
        total = quantity * price
        
        # Добавляем покупку в список
        expense = {
            "date": date,
            "product": product,
            "quantity": quantity,
            "price": price,
            "total": total,
            "store": store
        }
        
        self.data["expenses"].append(expense)
        self.save_data()
        
        # Очищаем поля
        self.product_var.set("")
        self.quantity_var.set("1")
        self.price_var.set("")
        self.store_var.set("")
        
        # Обновляем отображение
        self.update_expense_list()
        self.update_statistics()
        messagebox.showinfo("Успех", "Покупка добавлена!")
    
    def fill_price(self, event=None):
        """Автозаполнение цены при выборе продукта"""
        product_name = self.product_var.get()
        for product in self.data["products"]:
            if product["name"] == product_name:
                self.price_var.set(str(product["default_price"]))
                break
    
    def add_product(self):
        """Добавление нового продукта"""
        name = self.new_product_name.get()
        category = self.new_product_category.get()
        price = self.new_product_price.get()
        unit = self.new_product_unit.get()
        
        if not name:
            messagebox.showerror("Ошибка", "Введите название продукта")
            return
        
        try:
            price = float(price)
        except ValueError:
            messagebox.showerror("Ошибка", "Введите корректную цену")
            return
        
        # Проверяем, существует ли уже такой продукт
        for product in self.data["products"]:
            if product["name"] == name:
                # Обновляем существующий
                product["category"] = category
                product["default_price"] = price
                product["unit"] = unit
                self.save_data()
                self.update_product_list()
                self.update_statistics()
                messagebox.showinfo("Успех", "Продукт обновлен!")
                return
        
        # Добавляем новый продукт
        new_product = {
            "name": name,
            "category": category if category else "Другое",
            "default_price": price,
            "unit": unit
        }
        
        self.data["products"].append(new_product)
        self.save_data()
        
        # Очищаем поля
        self.new_product_name.set("")
        self.new_product_category.set("")
        self.new_product_price.set("")
        
        self.update_product_list()
        self.update_statistics()
        messagebox.showinfo("Успех", "Продукт добавлен!")
    
    def update_product_list(self):
        """Обновление списка продуктов в комбобоксе и таблице"""
        # Обновляем комбобокс
        product_names = [p["name"] for p in self.data["products"]]
        self.product_combo['values'] = product_names
        
        # Обновляем таблицу продуктов
        for item in self.products_tree.get_children():
            self.products_tree.delete(item)
        
        for product in self.data["products"]:
            self.products_tree.insert('', 'end', values=(
                product["name"],
                product.get("category", "Другое"),
                f"{product['default_price']} ₽",
                product.get("unit", "шт")
            ))
    
    def update_expense_list(self):
        """Обновление списка покупок"""
        for item in self.expense_tree.get_children():
            self.expense_tree.delete(item)
        
        # Сортируем по дате (новые сверху)
        sorted_expenses = sorted(self.data["expenses"], 
                               key=lambda x: x["date"], 
                               reverse=True)
        
        for expense in sorted_expenses[-50:]:  # Показываем последние 50
            self.expense_tree.insert('', 'end', values=(
                expense["date"],
                expense["product"],
                expense["quantity"],
                f"{expense['price']} ₽",
                f"{expense['total']:.2f} ₽",
                expense.get("store", "")
            ))
    
    def update_statistics(self):
        """Обновление статистики"""
        now = datetime.now()
        current_month = now.month
        current_year = now.year
        
        # Фильтруем расходы за текущий месяц
        monthly_expenses = []
        for exp in self.data["expenses"]:
            exp_date = datetime.strptime(exp["date"], "%Y-%m-%d")
            if exp_date.month == current_month and exp_date.year == current_year:
                monthly_expenses.append(exp)
        
        # Подсчитываем общую сумму
        total_monthly = sum(exp["total"] for exp in monthly_expenses)
        
        # Среднее в день
        days_passed = now.day
        daily_avg = total_monthly / days_passed if days_passed > 0 else 0
        
        # Прогноз на месяц
        days_in_month = calendar.monthrange(current_year, current_month)[1]
        forecast = daily_avg * days_in_month
        
        # Обновляем метки
        self.monthly_total_label.config(text=f"{total_monthly:.2f} ₽")
        self.daily_avg_label.config(text=f"{daily_avg:.2f} ₽")
        self.forecast_label.config(text=f"{forecast:.2f} ₽")
        
        # Обновляем график
        self.update_chart(monthly_expenses)
        
        # Обновляем статистику по категориям
        self.update_category_stats(monthly_expenses)
    
    def update_chart(self, monthly_expenses):
        """Обновление графика расходов"""
        self.ax.clear()
        
        if not monthly_expenses:
            self.ax.text(0.5, 0.5, 'Нет данных за текущий месяц', 
                       ha='center', va='center', transform=self.ax.transAxes)
            self.canvas.draw()
            return
        
        # Группируем расходы по дням
        daily_expenses = defaultdict(float)
        for exp in monthly_expenses:
            day = datetime.strptime(exp["date"], "%Y-%m-%d").day
            daily_expenses[day] += exp["total"]
        
        days = sorted(daily_expenses.keys())
        amounts = [daily_expenses[day] for day in days]
        
        # Создаем график
        self.ax.bar(days, amounts, color='skyblue', alpha=0.7)
        self.ax.plot(days, amounts, 'ro-', linewidth=2, markersize=6)
        self.ax.set_xlabel('День месяца')
        self.ax.set_ylabel('Сумма (₽)')
        self.ax.set_title('Расходы по дням')
        self.ax.grid(True, alpha=0.3)
        
        # Добавляем подписи значений
        for i, (day, amount) in enumerate(zip(days, amounts)):
            self.ax.text(day, amount, f'{amount:.0f}', ha='center', va='bottom')
        
        self.figure.tight_layout()
        self.canvas.draw()
    
    def update_category_stats(self, monthly_expenses):
        """Обновление статистики по категориям"""
        # Очищаем таблицу
        for item in self.category_tree.get_children():
            self.category_tree.delete(item)
        
        # Создаем словарь продуктов
        product_dict = {p["name"]: p for p in self.data["products"]}
        
        # Группируем по категориям
        category_expenses = defaultdict(float)
        total = 0
        
        for exp in monthly_expenses:
            product = product_dict.get(exp["product"])
            if product:
                category = product.get("category", "Другое")
                category_expenses[category] += exp["total"]
                total += exp["total"]
        
        # Добавляем в таблицу
        for category, amount in sorted(category_expenses.items(), 
                                      key=lambda x: x[1], reverse=True):
            percentage = (amount / total * 100) if total > 0 else 0
            self.category_tree.insert('', 'end', values=(
                category,
                f"{amount:.2f} ₽",
                f"{percentage:.1f}%"
            ))
    
    def delete_expense(self):
        """Удаление выбранной покупки"""
        selected = self.expense_tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите покупку для удаления")
            return
        
        # Получаем значения выбранной строки
        values = self.expense_tree.item(selected[0])['values']
        
        # Ищем и удаляем запись
        for i, exp in enumerate(self.data["expenses"]):
            if (exp["date"] == values[0] and 
                exp["product"] == values[1] and 
                exp["quantity"] == float(values[2]) and
                exp["total"] == float(values[4].replace(" ₽", ""))):
                
                if messagebox.askyesno("Подтверждение", 
                                      f"Удалить покупку {values[1]} от {values[0]}?"):
                    del self.data["expenses"][i]
                    self.save_data()
                    self.update_expense_list()
                    self.update_statistics()
                break
    
    def delete_product(self):
        """Удаление продукта"""
        selected = self.products_tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите продукт для удаления")
            return
        
        values = self.products_tree.item(selected[0])['values']
        product_name = values[0]
        
        if messagebox.askyesno("Подтверждение", 
                              f"Удалить продукт {product_name}? Связанные покупки останутся."):
            self.data["products"] = [p for p in self.data["products"] 
                                    if p["name"] != product_name]
            self.save_data()
            self.update_product_list()
            self.update_statistics()
    
    def update_price(self):
        """Обновление цены продукта"""
        selected = self.products_tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите продукт для обновления цены")
            return
        
        values = self.products_tree.item(selected[0])['values']
        product_name = values[0]
        
        # Находим продукт
        for product in self.data["products"]:
            if product["name"] == product_name:
                # Открываем диалог для ввода новой цены
                dialog = tk.Toplevel(self.root)
                dialog.title("Обновить цену")
                dialog.geometry("300x150")
                
                ttk.Label(dialog, text=f"Новая цена для {product_name}:").pack(pady=10)
                new_price_var = tk.StringVar(value=str(product["default_price"]))
                ttk.Entry(dialog, textvariable=new_price_var).pack(pady=10)
                
                def save_new_price():
                    try:
                        new_price = float(new_price_var.get())
                        product["default_price"] = new_price
                        self.save_data()
                        self.update_product_list()
                        dialog.destroy()
                        messagebox.showinfo("Успех", "Цена обновлена!")
                    except ValueError:
                        messagebox.showerror("Ошибка", "Введите корректную цену")
                
                ttk.Button(dialog, text="Сохранить", command=save_new_price).pack(pady=10)
                break
    
    def update_monthly_stats(self):
        """Обновление месячной статистики"""
        self.update_statistics()
        self.update_expense_list()

def main():
    root = tk.Tk()
    app = FoodExpenseTracker(root)
    root.mainloop()

if __name__ == "__main__":
    main()