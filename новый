        info_frame = ttk.Frame(self.stats_frame)
        info_frame.pack(fill='x', padx=10, pady=10)
        
        # Месячные затраты
        monthly_frame = ttk.LabelFrame(info_frame, text="Затраты за месяц", padding=10)
        monthly_frame.pack(side='left', fill='both', expand=True, padx=5)
        
        self.monthly_total_label = ttk.Label(monthly_frame, text="0 ₽", 
