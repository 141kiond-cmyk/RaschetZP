        # Таблица последних расходов
        history_frame = ttk.LabelFrame(self.expense_frame, text="История покупок", padding=10)
        history_frame.pack(fill='both', expand=True, padx=10, pady=10)
        
        # Создаем таблицу
        columns = ('date', 'product', 'quantity', 'price', 'total', 'store')
        self.expense_tree = ttk.Treeview(history_frame, columns=columns, show='headings')
        
