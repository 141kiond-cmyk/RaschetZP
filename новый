import tkinter as tk
from tkinter import ttk, messagebox
import json
from datetime import datetime, timedelta
import calendar
from collections import defaultdict
import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
import os

class FoodExpenseTracker:
    def __init__(self, root):
        self.root = root
        self.root.title("Калькулятор затрат на еду")
        self.root.geometry("1200x700")
        
        # Файл для хранения данных
        self.data_file = "food_expenses.json"
        
        # Загрузка данных
        self.load_data()
        
        # Создание интерфейса
        self.create_widgets()
        
        # Обновление статистики
        self.update_statistics()
        self.update_product_list()
        self.update_monthly_stats()
    
    def load_data(self):
        """Загрузка данных из файла"""
        if os.path.exists(self.data_file):
            with open(self.data_file, 'r', encoding='utf-8') as f:
                self.data = json.load(f)
        else:
            self.data = {
                "products": [],  # Список продуктов с ценами
                "expenses": []   # Список покупок
            }
    
    def save_data(self):
        """Сохранение данных в файл"""
        with open(self.data_file, 'w', encoding='utf-8') as f:
            json.dump(self.data, f, ensure_ascii=False, indent=2)
    
    def create_widgets(self):
        """Создание интерфейса"""
        # Создаем вкладки
        notebook = ttk.Notebook(self.root)
        notebook.pack(fill='both', expand=True, padx=10, pady=10)
        
        # Вкладка добавления расходов
        self.expense_frame = ttk.Frame(notebook)
        notebook.add(self.expense_frame, text='Добавление расходов')
        self.create_expense_tab()
        
        # Вкладка списка продуктов
        self.products_frame = ttk.Frame(notebook)
        notebook.add(self.products_frame, text='Список продуктов')
        self.create_products_tab()
        
        # Вкладка статистики
        self.stats_frame = ttk.Frame(notebook)
        notebook.add(self.stats_frame, text='Статистика')
        self.create_stats_tab()
    
