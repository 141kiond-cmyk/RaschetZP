        # Добавляем скроллбар
        scrollbar = ttk.Scrollbar(history_frame, orient='vertical', command=self.expense_tree.yview)
        self.expense_tree.configure(yscrollcommand=scrollbar.set)
        
        self.expense_tree.pack(side='left', fill='both', expand=True)
        scrollbar.pack(side='right', fill='y')
        
        # Кнопки управления
        btn_frame = ttk.Frame(history_frame)
        btn_frame.pack(fill='x', pady=5)
        
        ttk.Button(btn_frame, text="Удалить выбранное", 
                  command=self.delete_expense).pack(side='left', padx=5)
        ttk.Button(btn_frame, text="Обновить список", 
                  command=self.update_expense_list).pack(side='left', padx=5)
    
